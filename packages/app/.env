# duplicate this file and call it '.env.local' to override defaults
VITE_DEFAULT_POINT_COUNT=1e5
VITE_DEFAULT_RENDER_INTERVAL_MS=1
VITE_DEFAULT_RESOLUTION=1
VITE_DEFAULT_ZOOM_LEVEL=1
VITE_DEFAULT_QUALITY=0.95
VITE_DEFAULT_HIGH_QUALITY=0.95
VITE_DEFAULT_ULTRA_QUALITY=0.995
VITE_DEFAULT_VARIATION_SHOW_DELAY_MS=50
VITE_DEFAULT_PREVIEW_PIXEL_RATIO=1
VITE_DEFAULT_VARIATION_PREVIEW_POINT_COUNT=1e5
VITE_DEFAULT_VARIATION_PREVIEW_RENDER_INTERVAL_MS=10
VITE_STATIC_PREVIEW_POINT_COUNT=1e5
VITE_ANIMATION_PREVIEW_QUALITY=0.995
VITE_ANIMATION_PREVIEW_POINT_COUNT=1e5
VITE_THUMBNAIL_PREVIEW_QUALITY=0.95
VITE_THUMBNAIL_PREVIEW_QUALITY_HOVER=0.999
VITE_COMPUTE_GATE_CAPACITY=2

# Animation frame preview quality presets (for animation export gallery thumbnails)
VITE_ANIMATION_FRAME_PREVIEW_QUALITY_LOW=0.95
VITE_ANIMATION_FRAME_PREVIEW_QUALITY_MID=0.98
VITE_ANIMATION_FRAME_PREVIEW_QUALITY_HIGH=0.99

# Set to 'true' to force show welcome screen on startup (useful for development)
# Defaults to showing welcome screen on first visit when not set
VITE_SHOW_WELCOME_ON_STARTUP=false
VITE_CANVAS_RESIZE_DEBOUNCE_MS=200
