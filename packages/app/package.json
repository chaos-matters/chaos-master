{
  "name": "chaos-master",
  "version": "0.8.7",
  "description": "WebGPU based IFS Flame Generator for Artists & Explorers",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "serve": "vite preview",
    "prod": "vite build && vite preview",
    "start": "vite",
    "test": "vitest",
    "analyze-bundle": "VITE_ANALYZE_BUNDLE=true vite build",
    "deploy:dev": "pnpm exec wrangler deploy --env dev",
    "deploy:prod": "pnpm exec wrangler deploy --env prod"
  },
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@typegpu/color": "0.10.0",
    "@typegpu/noise": "0.10.0",
    "@typegpu/sdf": "0.10.0",
    "@vercel/analytics": "1.6.1",
    "dexie": "^4.4.2",
    "mp4-muxer": "^5.2.2",
    "solid-devtools": "^0.34.5",
    "solid-js": "1.9.11",
    "structurajs": "0.12.6",
    "typegpu": "0.10.2",
    "valibot": "1.2.0",
    "wgpu-matrix": "3.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "vite-plugin-qrcode": "^0.4.1",
    "wrangler": "^4.92.0"
  }
}
