{
  "name": "chaos-master",
  "version": "0.9.3",
  "description": "WebGPU based IFS Flame Generator for Artists & Explorers",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "serve": "vite preview",
    "prod": "vite build && vite preview",
    "start": "vite",
    "test": "vitest",
    "analyze-bundle": "VITE_ANALYZE_BUNDLE=true vite build",
    "deploy:dev": "pnpm exec wrangler deploy --env dev",
    "deploy:prod": "pnpm exec wrangler deploy --env prod",
    "r2:create:dev": "pnpm exec wrangler r2 bucket create chaos-master-og-images-dev",
    "r2:create:prod": "pnpm exec wrangler r2 bucket create chaos-master-og-images"
  },
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@solid-primitives/upload": "^0.1.4",
    "@typegpu/color": "0.10.0",
    "@typegpu/noise": "0.10.0",
    "@typegpu/sdf": "0.10.0",
    "@vercel/analytics": "1.6.1",
    "acorn": "^8.16.0",
    "dexie": "^4.4.2",
    "marked": "^18.0.4",
    "mathjax": "^4.1.2",
    "mp4-muxer": "^5.2.2",
    "solid-devtools": "^0.34.5",
    "solid-js": "1.9.11",
    "structurajs": "0.12.6",
    "tinyest-for-wgsl": "^0.3.3",
    "typegpu": "0.10.2",
    "valibot": "1.2.0",
    "wgpu-matrix": "3.4.2"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.19.1",
    "@codemirror/lint": "^6.8.6",
    "@codemirror/search": "^6.5.11",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "vite-plugin-qrcode": "^0.4.1",
    "wrangler": "^4.92.0"
  }
}
